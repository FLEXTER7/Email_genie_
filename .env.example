# ──────────────────────────────────────────────────────────────────
# Email Genie — environment variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────
PORT=3000

# Secret token that the admin panel sends in the X-Admin-Token header.
# Change this to a long random string before deploying.
ADMIN_SECRET=change-me-in-production

# ── Twilio (SMS) ─────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Twilio phone number in E.164 format, e.g. +15550001234
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── SMTP (outbound email + SMS gateway fallback) ──────────────────
# Mailgun SMTP example:
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
#   SMTP_USER=postmaster@emailgenie.org
#   SMTP_PASS=<mailgun-smtp-password>
#   SMTP_FROM=noreply@emailgenie.org
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@emailgenie.org
SMTP_PASS=your-mailgun-smtp-password
SMTP_FROM=noreply@emailgenie.org

# ── Database ─────────────────────────────────────────────────────
# Leave blank to use the default ./data/emailgenie.db (SQLite).
# Set to a PostgreSQL connection string to switch to Postgres.
DB_PATH=./data/emailgenie.db

# ── CORS ─────────────────────────────────────────────────────────
# Restrict to your frontend domain in production, e.g. https://emailgenie.org
CORS_ORIGIN=*
